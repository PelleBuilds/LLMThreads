@{
}
@using ThreadMapLLM.Models
<header>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, height=device-height, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication2</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
   
</header>
@Html.AntiForgeryToken()
@model LoginViewModel
<body class=" bg-dark align-content-center" >
    <div class="bg-dark m-auto col-md-5 shadow rounded-3" id="main-Container">
    <div class="text-center mt-5 fw-bold text-white">Login</div>
<div>

        <form asp-action="Login" method="post" class ="input-group w-50 row mx-auto  mb-4">
            <div class="mt-3">
                <div><input type="text" name="Username" class="form-control mb-2 text-bg-dark" placeholder="Username text-white" /></div>
                <div><input type="password" name="Password" class="form-control mb-2 text-bg-dark" placeholder="****" /></div>
            </div>
            <div>
                <button type="submit" name="action" value="Login" class="btn mb-2 btn-primary rounded-3">Login</button>
                <button type="submit" name="action" value="ForgotPassword" class="btn mb-2 btn-primary accept-policy rounded-3">Forgot password</button>
            </div>
    </form>
        </div>
    </div>
</body>